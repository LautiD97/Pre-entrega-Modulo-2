# Puerto HTTP utilizado por el servidor Express.
# Si se utiliza la configuración estándar del proyecto, puede establecerse en 8080.
PORT=8080

# URI de conexión a MongoDB.
# Para una instancia local, por ejemplo:
# mongodb://127.0.0.1:27017/shipnow
#
# Si se utiliza MongoDB Atlas, reemplazar este valor por la URI correspondiente.
# Nunca incluir credenciales reales en este archivo de ejemplo.
MONGODB_URI=mongodb://127.0.0.1:27017/shipnow

# Entorno en el que se ejecuta la aplicación.
# Valores habituales: development, test o production.
NODE_ENV=development